generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Gender {
  MALE
  FEMALE
}

enum MatchResult {
  WIN
  LOSS
}

enum RoundType {
  GROUP
  SEMI
  FINAL
}

enum CategoryCode {
  MEN_ADVANCED
  MEN_MIXED
  MEN_INTERMEDIATE
  MIXED_ADVANCED
  MIXED_INTERMEDIATE
  WOMEN_DOUBLE
}

enum SlotSide {
  A
  B
}

enum SlotSourceType {
  STATIC
  FROM_MATCH
}

enum Role {
  ADMIN
  USER
}

//////////////////////////////////////////////////////
// CORE
//////////////////////////////////////////////////////

model User {
  id      String  @id @default(uuid())
  username String @unique
  password String
  role    Role

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt 
}

model Team {
  id            String   @id @default(uuid())
  name          String

  players       Player[]
  doubles       Double[]
  wonMatches    Match[]
  matchResults  MatchResultLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Player {
  id      String  @id @default(uuid())
  name    String
  gender  Gender
  level   Int

  teamId  String
  team    Team @relation(fields: [teamId], references: [id])

  doublesAsPlayer1 Double[] @relation("Player1")
  doublesAsPlayer2 Double[] @relation("Player2")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([teamId])
}

model Double {
  id          String @id @default(uuid())
  point       Int

  player1Id   String
  player2Id   String

  player1     Player @relation("Player1", fields: [player1Id], references: [id])
  player2     Player @relation("Player2", fields: [player2Id], references: [id])

  teamId      String
  team        Team @relation(fields: [teamId], references: [id])

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  matchA      Match[] @relation("MatchA")
  matchB      Match[] @relation("MatchB")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([teamId])
  @@index([categoryId])
}

model Category {
  id      String       @id @default(uuid())
  code    CategoryCode @unique
  name    String

  doubles         Double[]
  timelineMatches TimelineMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Round {
  id        String    @id @default(uuid())
  name      RoundType @unique

  pointWin  Int
  pointLoss Int

  timelineMatches TimelineMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

//////////////////////////////////////////////////////
// TIMELINE
//////////////////////////////////////////////////////

model TimelineMatch {
  id         String @id @default(uuid())

  roundId    String
  round      Round @relation(fields: [roundId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  order      Int
  roundOrder Int

  slots       MatchSlot[]
  matches     Match[]
  sourceSlots MatchSlot[] @relation("SourceMatch")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([roundId, categoryId, order])
  @@index([roundId])
  @@index([categoryId])
}

model MatchSlot {
  id              String @id @default(uuid())

  timelineMatchId String
  timelineMatch   TimelineMatch @relation(fields: [timelineMatchId], references: [id])

  side            SlotSide
  sourceType      SlotSourceType

  staticKey       String?

  sourceMatchId   String?
  sourceMatch     TimelineMatch? @relation("SourceMatch", fields: [sourceMatchId], references: [id])

  sourceResult    MatchResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([timelineMatchId])
  @@index([sourceMatchId])
}

//////////////////////////////////////////////////////
// RUNTIME MATCH
//////////////////////////////////////////////////////

model Match {
  id              String @id @default(uuid())

  timelineMatchId String
  timelineMatch   TimelineMatch @relation(fields: [timelineMatchId], references: [id])

  doubleAId       String
  doubleBId       String

  doubleA         Double @relation("MatchA", fields: [doubleAId], references: [id])
  doubleB         Double @relation("MatchB", fields: [doubleBId], references: [id])

  winnerTeamId    String?
  winnerTeam      Team? @relation(fields: [winnerTeamId], references: [id])

  playedAt        DateTime?

  setScores       SetScore[]
  resultLogs      MatchResultLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([timelineMatchId])
}

model SetScore {
  id        String @id @default(uuid())

  matchId   String
  match     Match @relation(fields: [matchId], references: [id])

  setNumber Int
  scoreA    Int
  scoreB    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([matchId, setNumber])
  @@index([matchId])
}

model MatchResultLog {
  id      String @id @default(uuid())

  matchId String
  match   Match @relation(fields: [matchId], references: [id])

  teamId  String
  team    Team @relation(fields: [teamId], references: [id])

  result  MatchResult
  points  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([matchId])
  @@index([teamId])
}