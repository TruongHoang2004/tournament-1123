generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum MatchResult {
  WIN
  LOSS
}

enum RoundType {
  GROUP
  SEMI
  FINAL
}

enum CategoryCode {
  MEN_ADVANCED
  MEN_MIXED
  MEN_INTERMEDIATE
  MIXED_ADVANCED
  MIXED_INTERMEDIATE
  WOMEN_DOUBLE
}

model Tournament {
  id        String   @id @default(uuid())
  name      String
  date      DateTime
  createdAt DateTime @default(now())

  teams     Team[]
  rounds    Round[]
  groups    Group[]
  matches   Match[]
}

model Team {
  id              String   @id @default(uuid())
  name            String
  tournamentId    String
  tournament      Tournament @relation(fields: [tournamentId], references: [id])

  players         Player[]
  matches         Match[]   @relation("TeamMatches")
  opponentMatches Match[]   @relation("OpponentMatches")

  teamGroups      TeamGroup[]
}

model Player {
  id      String @id @default(uuid())
  name    String
  gender  Gender
  level   Int

  teamId  String
  team    Team @relation(fields: [teamId], references: [id])

  matchesAsP1 Match[] @relation("Player1")
  matchesAsP2 Match[] @relation("Player2")
}

model Category {
  id    String       @id @default(uuid())
  code  CategoryCode @unique
  name  String

  matches Match[]
}

model Round {
  id            String    @id @default(uuid())
  name          RoundType
  tournamentId  String
  tournament    Tournament @relation(fields: [tournamentId], references: [id])

  pointWin      Int
  pointLoss     Int

  matches       Match[]
}

model Group {
  id           String   @id @default(uuid())
  name         String
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  teams        TeamGroup[]
  matches      Match[]
}

model TeamGroup {
  teamId  String
  groupId String

  team    Team  @relation(fields: [teamId], references: [id])
  group   Group @relation(fields: [groupId], references: [id])

  @@id([teamId, groupId])
}

model Match {
  id             String   @id @default(uuid())

  tournamentId   String
  tournament     Tournament @relation(fields: [tournamentId], references: [id])

  roundId        String
  round          Round @relation(fields: [roundId], references: [id])

  groupId        String?
  group          Group? @relation(fields: [groupId], references: [id])

  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])

  teamId         String
  team           Team @relation("TeamMatches", fields: [teamId], references: [id])

  opponentTeamId String?
  opponentTeam   Team? @relation("OpponentMatches", fields: [opponentTeamId], references: [id])

  player1Id      String
  player1        Player @relation("Player1", fields: [player1Id], references: [id])

  player2Id      String
  player2        Player @relation("Player2", fields: [player2Id], references: [id])

  result         MatchResult
  points         Int

  playedAt       DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([teamId])
  @@index([roundId])
  @@index([categoryId])
}